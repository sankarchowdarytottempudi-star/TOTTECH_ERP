generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ai_student_analysis {
  id                     Int       @id @default(autoincrement())
  school_id              Int?
  student_id             Int?
  subject_id             Int?
  weakness_area          String?
  improvement_suggestion String?
  predicted_score        Decimal?  @db.Decimal(5, 2)
  risk_level             String?   @db.VarChar(50)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  schools                schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects               subjects? @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model attendance {
  id              Int       @id @default(autoincrement())
  school_id       Int?
  student_id      Int?
  attendance_date DateTime  @db.Date
  status          String?   @db.VarChar(20)
  remarks         String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  schools         schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model audit_logs {
  id             Int       @id @default(autoincrement())
  school_id      Int?
  user_id        Int?
  action_type    String?   @db.VarChar(100)
  action_details String?
  ip_address     String?   @db.VarChar(100)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  schools        schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model classes {
  id               Int        @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  class_name       String     @db.VarChar(100)
  class_teacher_id Int?
  created_by       Int?
  created_at       DateTime?  @default(now()) @db.Timestamp(6)
  teachers         teachers?  @relation(fields: [class_teacher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools          schools?   @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fees             fees[]
  sections         sections[]
}

model exams {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  exam_name        String?   @db.VarChar(255)
  exam_type        String?   @db.VarChar(100)
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  created_by       Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  schools    schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  marks      marks[]
  student_backlogs student_backlogs[]
}

model fee_payments {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  student_id       Int?
  fee_id           Int?
  paid_amount      Decimal?  @db.Decimal(12, 2)
  payment_date     DateTime? @db.Date
  payment_mode     String?   @db.VarChar(50)
  transaction_id   String?   @db.VarChar(255)
  created_by       Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  fees           fees?     @relation(fields: [fee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools        schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model fees {
  id               Int            @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  class_id         Int?
  fee_type         String?        @db.VarChar(100)
  amount           Decimal?       @db.Decimal(12, 2)
  due_date         DateTime?      @db.Date
  created_by       Int?
  created_at       DateTime?      @default(now()) @db.Timestamp(6)
  fee_payments fee_payments[]
  classes      classes?       @relation(fields: [class_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools      schools?       @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model hostel_rooms {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  room_number      String?   @db.VarChar(50)
  hostel_name      String?   @db.VarChar(255)
  capacity         Int?
  created_by       Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  schools     schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model marks {
  id             Int       @id @default(autoincrement())
  school_id      Int?
  student_id     Int?
  subject_id     Int?
  exam_id        Int?
  total_marks    Decimal?  @db.Decimal(5, 2)
  obtained_marks Decimal?  @db.Decimal(5, 2)
  grade          String?   @db.VarChar(10)
  remarks        String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  exams          exams?    @relation(fields: [exam_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools        schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects       subjects? @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  id                Int       @id @default(autoincrement())
  school_id         Int?
  student_id        Int?
  notification_type String?   @db.VarChar(100)
  channel           String?   @db.VarChar(30)
  recipient_phone   String?   @db.VarChar(50)
  message           String?
  sent_status       Boolean?  @default(false)
  delivery_status   String?   @default("PENDING") @db.VarChar(50)
  opened_at         DateTime? @db.Timestamp(6)
  read_at           DateTime? @db.Timestamp(6)
  failed_at         DateTime? @db.Timestamp(6)
  metadata          Json?     @default("{}")
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  schools           schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model schools {
  id                  Int                   @id @default(autoincrement())
  school_name         String                @db.VarChar(255)
  school_code         String                @unique @db.VarChar(50)
  email               String?               @db.VarChar(255)
  phone               String?               @db.VarChar(20)
  address             String?
  logo_url            String?
  school_logo         String?
  favicon_url         String?
  school_favicon      String?
  primary_color       String?               @default("#04142E") @db.VarChar(30)
  secondary_color     String?               @default("#D4AF37") @db.VarChar(30)
  city                String?               @db.VarChar(120)
  state               String?               @db.VarChar(120)
  country             String?               @default("India") @db.VarChar(120)
  postal_code         String?               @db.VarChar(30)
  website             String?
  principal_name      String?               @db.VarChar(255)
  principal_contact   String?               @db.VarChar(50)
  owner_name          String?               @db.VarChar(255)
  owner_contact       String?               @db.VarChar(50)
  subscription_plan   String?               @default("BASIC") @db.VarChar(50)
  subscription_status String?               @default("ACTIVE") @db.VarChar(50)
  max_students        Int?                  @default(500)
  is_active           Boolean?              @default(true)
  branding            Json?                 @default("{}")
  ai_branding_name    String?               @db.VarChar(255)
  report_branding     Json?                 @default("{}")
  certificate_branding Json?                @default("{}")
  recognition_number  String?               @db.VarChar(120)
  recognition_authority String?             @db.VarChar(255)
  recognition_start_date DateTime?           @db.Date
  recognition_expiry_date DateTime?          @db.Date
  affiliation_number  String?               @db.VarChar(120)
  affiliation_authority String?             @db.VarChar(255)
  affiliation_start_date DateTime?           @db.Date
  affiliation_expiry_date DateTime?          @db.Date
  settings            Json?                 @default("{}")
  created_by          Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_by          Int?
  updated_at          DateTime?             @db.Timestamp(6)
  ai_student_analysis ai_student_analysis[]
  attendance          attendance[]
  audit_logs          audit_logs[]
  classes             classes[]
  exams               exams[]
  fee_payments        fee_payments[]
  fees                fees[]
  hostel_rooms        hostel_rooms[]
  marks               marks[]
  notifications       notifications[]
  sections            sections[]
  subjects            subjects[]
  teachers            teachers[]
  student_learning_gaps student_learning_gaps[]
  student_backlogs    student_backlogs[]
  teacher_teaching_gaps teacher_teaching_gaps[]
  transport_routes    transport_routes[]
  users               users[]
  user_school_access  user_school_access[]
  user_module_access  user_module_access[]
  school_module_access school_module_access[]
  hr_staff_master    hr_staff_master[]
  hr_leave_categories hr_leave_categories[]
  hr_leave_allocations hr_leave_allocations[]
  hr_lop_entries     hr_lop_entries[]
  hr_leave_requests  hr_leave_requests[]
  hr_salary_structures hr_salary_structures[]
  hr_salary_assignments hr_salary_assignments[]
  hr_salary_history  hr_salary_history[]
  hr_increment_requests hr_increment_requests[]
  hr_payroll_runs    hr_payroll_runs[]
  hr_pay_slips       hr_pay_slips[]
  hr_pf_ledgers      hr_pf_ledgers[]
  hr_approval_center hr_approval_center[]
  hr_event_ledger    hr_event_ledger[]
}

model sections {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  class_id         Int?
  section_name     String?   @db.VarChar(50)
  created_by       Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  classes      classes?  @relation(fields: [class_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools      schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model students {
  id                 Int       @id @default(autoincrement())
  enrollment_number  String?   @db.VarChar(100)
  admission_number   String?   @db.VarChar(100)
  name               String?   @db.VarChar(255)
  first_name         String?   @db.VarChar(100)
  middle_name        String?   @db.VarChar(100)
  last_name          String?   @db.VarChar(100)
  gender             String?   @db.VarChar(20)
  dob                DateTime? @db.Date
  phone              String?   @db.VarChar(20)
  email              String?   @db.VarChar(255)
  address            String?
  admission_date     DateTime? @db.Date
  religion           String?   @db.VarChar(100)
  caste              String?   @db.VarChar(100)
  blood_group        String?   @db.VarChar(20)
  father_name        String?   @db.VarChar(255)
  mother_name        String?   @db.VarChar(255)
  father_phone       String?   @db.VarChar(20)
  mother_phone       String?   @db.VarChar(20)
  father_alternative_mobile String? @db.VarChar(20)
  mother_alternative_mobile String? @db.VarChar(20)
  guardian_alternative_mobile String? @db.VarChar(20)
  emergency_contact_number String? @db.VarChar(20)
  emergency_contact_name String? @db.VarChar(255)
  emergency_relationship String? @db.VarChar(100)
  father_occupation  String?   @db.VarChar(255)
  mother_occupation  String?   @db.VarChar(255)
  roll_number        String?   @db.VarChar(100)
  section_id         Int?
  session_id         Int?
  is_active          Boolean?  @default(true)
  city               String?   @db.VarChar(100)
  state              String?   @db.VarChar(100)
  country            String?   @db.VarChar(100)
  medium             String?   @db.VarChar(100)
  house              String?   @db.VarChar(100)
  category           String?   @db.VarChar(100)
  birth_place        String?   @db.VarChar(255)
  mother_tongue      String?   @db.VarChar(100)
  school_name        String?   @db.VarChar(255)
  school_address     String?
  school_class       String?   @db.VarChar(100)
  pass_out_year      String?   @db.VarChar(20)
  pan                String?   @db.VarChar(100)
  student_type       String?   @db.VarChar(50)
  note               String?
  survey             String?   @db.VarChar(255)
  pen                String?   @db.VarChar(255)
  apaar              String?   @db.VarChar(255)
  father_id_number   String?   @db.VarChar(255)
  mother_id_number   String?   @db.VarChar(255)
  is_suspended       Boolean?  @default(false)
  suspend_start_date DateTime? @db.Date
  suspend_end_date   DateTime? @db.Date
  suspend_message    String?
  uid                String?   @db.VarChar(255)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  school_id          Int?
  academic_year_id   Int?
  academic_year      String?   @db.VarChar(50)
  has_previous_school Boolean? @default(false)
  has_backlogs       Boolean?  @default(false)
  previous_school_name String? @db.VarChar(255)
  previous_school_address String?
  previous_school_details String?
  previous_board     String?   @db.VarChar(255)
  previous_class_studied String? @db.VarChar(100)
  previous_academic_year String? @db.VarChar(50)
  previous_academic_performance String? @db.VarChar(80)
  previous_school_percentage Decimal? @db.Decimal(5, 2)
  previous_school_grade String? @db.VarChar(20)
  previous_school_tc_number String? @db.VarChar(120)
  previous_school_leaving_date DateTime? @db.Date
  previous_school_reason_for_leaving String?
  has_academic_gap   Boolean?  @default(false)
  academic_gap_from_year String? @db.VarChar(50)
  academic_gap_to_year String? @db.VarChar(50)
  academic_gap_duration String? @db.VarChar(100)
  academic_gap_reason String?
  current_class_id   Int?
  current_section_id Int?
  created_by         Int?
  transport_required Boolean?  @default(false)
  transport_route_id Int?
  hostel_required    Boolean?  @default(false)
  hostel_room_id     Int?
  photo_url          String?
  student_username   String?   @db.VarChar(255)
  parent_username    String?   @db.VarChar(255)
  guardian_username  String?   @db.VarChar(255)
  student_status     String?   @default("ACTIVE") @db.VarChar(40)
  status_updated_at  DateTime? @db.Timestamp(6)
  status_reason      String?
  learning_gaps      student_learning_gaps[]
  student_backlogs   student_backlogs[]
}

model subjects {
  id                  Int                   @id @default(autoincrement())
  school_id           Int?
  academic_year_id    Int?
  subject_name        String?               @db.VarChar(255)
  subject_code        String?               @db.VarChar(100)
  description         String?
  status              String?               @default("ACTIVE") @db.VarChar(30)
  created_by          Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  ai_student_analysis ai_student_analysis[]
  marks               marks[]
  student_backlogs    student_backlogs[]
  schools             schools?              @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([school_id, academic_year_id, status], map: "idx_subjects_school_year_status")
}

model teachers {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  academic_year_id Int?
  user_id          Int?
  staff_id         Int?      @unique
  employee_id      String?   @unique @db.VarChar(100)
  staff_type       String?   @default("Teaching") @db.VarChar(20)
  qualification    String?   @db.VarChar(255)
  experience_years Int?
  joining_date     DateTime? @db.Date
  salary           Decimal?  @db.Decimal(12, 2)
  department       String?   @db.VarChar(255)
  subject_specialization String? @db.Text
  created_by       Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  first_name       String?   @db.VarChar(100)
  last_name        String?   @db.VarChar(100)
  gender           String?   @db.VarChar(20)
  phone            String?   @db.VarChar(20)
  whatsapp_number  String?   @db.VarChar(20)
  alternative_mobile String? @db.VarChar(20)
  emergency_contact_number String? @db.VarChar(20)
  emergency_contact_person String? @db.VarChar(255)
  relationship     String?   @db.VarChar(100)
  email            String?   @db.VarChar(255)
  designation      String?   @db.VarChar(100)
  address          String?
  current_address  Json?
  permanent_address Json?
  employment_history Json?
  salary_history    Json?
  classes_handling Json?     @default("[]")
  sections_handling Json?     @default("[]")
  documents         Json?
  qualifications    Json?
  certifications    Json?
  teacher_notes     Json?
  performance_notes Json?
  is_active        Boolean?  @default(true)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  classes          classes[]
  schools          schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff_record     hr_staff_master? @relation("TeacherStaffLink")
  teaching_gaps    teacher_teaching_gaps[]
}

model student_learning_gaps {
  id               Int       @id @default(autoincrement())
  school_id        Int?
  student_id       Int?
  academic_year_id Int?
  gap_category     String?   @db.VarChar(100)
  subject          String?   @db.VarChar(255)
  description      String?
  severity         String?   @db.VarChar(50)
  identified_by    Int?
  identified_date  DateTime? @db.Date
  action_plan      String?
  target_date      DateTime? @db.Date
  status           String?   @default("OPEN") @db.VarChar(40)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  schools          schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students         students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?    @relation("student_gap_identified_by", fields: [identified_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model teacher_teaching_gaps {
  id                    Int       @id @default(autoincrement())
  school_id             Int?
  teacher_id            Int?
  academic_year_id      Int?
  gap_category          String?   @db.VarChar(100)
  description           String?
  severity              String?   @db.VarChar(50)
  training_recommendation String?
  target_date           DateTime? @db.Date
  status                String?   @default("OPEN") @db.VarChar(40)
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  updated_at            DateTime? @default(now()) @db.Timestamp(6)
  schools               schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers              teachers? @relation(fields: [teacher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transport_routes {
  id             Int       @id @default(autoincrement())
  school_id      Int?
  route_name     String?   @db.VarChar(255)
  vehicle_number String?   @db.VarChar(100)
  driver_name    String?   @db.VarChar(255)
  driver_phone   String?   @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  schools        schools?  @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id            Int          @id @default(autoincrement())
  school_id     Int?
  username      String?      @db.VarChar(120)
  full_name     String       @db.VarChar(255)
  email         String       @unique @db.VarChar(255)
  phone         String?      @db.VarChar(20)
  password_hash String
  platform_type String       @default("EDUCATIONAL") @db.VarChar(40)
  role          String       @db.VarChar(50)
  status        String       @default("ACTIVE") @db.VarChar(40)
  is_active     Boolean?     @default(true)
  is_deleted    Boolean?     @default(false)
  deleted_at    DateTime?    @db.Timestamp(6)
  deleted_by    Int?
  locked_at     DateTime?    @db.Timestamp(6)
  locked_by     Int?
  archived_at   DateTime?    @db.Timestamp(6)
  archived_by   Int?
  whatsapp_number String?    @db.VarChar(20)
  alternative_mobile String? @db.VarChar(20)
  emergency_contact_number String? @db.VarChar(20)
  preferred_language String? @default("en") @db.VarChar(10)
  last_login    DateTime?    @db.Timestamp(6)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  updated_at    DateTime?    @db.Timestamp(6)
  audit_logs    audit_logs[]
  teachers      teachers[]
  identified_student_gaps student_learning_gaps[] @relation("student_gap_identified_by")
  schools       schools?     @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_school_access user_school_access[]
  user_module_access user_module_access[]
}

model user_school_access {
  id         Int       @id @default(autoincrement())
  user_id    Int
  school_id  Int
  is_primary Boolean?  @default(false)
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  created_by Int?
  schools    schools   @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, school_id], map: "uq_user_school_access_user_school")
  @@index([user_id, is_active], map: "idx_user_school_access_user_active")
  @@index([school_id, is_active], map: "idx_user_school_access_school_active")
}

model module_master {
  id           Int      @id @default(autoincrement())
  module_key   String   @unique @db.VarChar(100)
  module_name  String   @db.VarChar(255)
  category     String?  @db.VarChar(80)
  sort_order   Int?     @default(0)
  is_active    Boolean? @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  user_module_access user_module_access[]
}

model user_module_access {
  id         Int      @id @default(autoincrement())
  user_id    Int
  school_id  Int
  module_id  Int
  created_by Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  is_active  Boolean?  @default(true)
  module_master module_master @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schools    schools   @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, school_id, module_id], map: "uq_user_module_access_scope")
  @@index([user_id, school_id, is_active], map: "idx_user_module_access_user_school")
  @@index([school_id, module_id, is_active], map: "idx_user_module_access_school_module")
}

model school_module_access {
  id         Int       @id @default(autoincrement())
  school_id  Int
  module_key String    @db.VarChar(80)
  enabled    Boolean   @default(false)
  enabled_by Int?
  enabled_at DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  schools    schools   @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([school_id, module_key], map: "school_module_access_school_id_module_key_key")
