  doctors       doctors?   @relation(fields: [doctor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments   departments? @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenant_id, clinic_id, appointment_date, status, is_deleted])
}

