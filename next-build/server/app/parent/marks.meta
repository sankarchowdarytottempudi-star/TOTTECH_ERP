{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/parent/layout,_N_T_/parent/marks/layout,_N_T_/parent/marks/page,_N_T_/parent/marks"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/parent/marks/__PAGE__",
    "/parent/marks",
    "/parent",
    "/_index",
    "/_head"
  ]
}