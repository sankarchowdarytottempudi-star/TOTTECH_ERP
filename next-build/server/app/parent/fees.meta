{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/parent/layout,_N_T_/parent/fees/layout,_N_T_/parent/fees/page,_N_T_/parent/fees"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/parent/fees/__PAGE__",
    "/parent/fees",
    "/parent",
    "/_index",
    "/_head"
  ]
}