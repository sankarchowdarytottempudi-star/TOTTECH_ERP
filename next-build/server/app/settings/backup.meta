{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/settings/layout,_N_T_/settings/backup/layout,_N_T_/settings/backup/page,_N_T_/settings/backup"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/settings/backup/__PAGE__",
    "/settings/backup",
    "/settings",
    "/_index",
    "/_head"
  ]
}