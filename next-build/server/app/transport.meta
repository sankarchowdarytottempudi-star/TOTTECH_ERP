{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/transport/layout,_N_T_/transport/page,_N_T_/transport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/transport/__PAGE__",
    "/transport",
    "/_index",
    "/_head"
  ]
}